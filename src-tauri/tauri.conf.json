{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qr-school-tour",
  "version": "0.1.0",
  "identifier": "com.mojaskola.qrapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://192.168.0.134:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "qr-school-tour",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
     "capabilities": ["mobile-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
